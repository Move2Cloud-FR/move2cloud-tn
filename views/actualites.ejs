  <style>
    * { font-family: 'Poppins', sans-serif; }
    html { scroll-behavior: smooth; }
    ::selection { background: #c70039; color: white; }

    .hero-bg {
      background: linear-gradient(135deg, #0a0a1a 0%, #1a0008 50%, #2a0010 100%);
    }
    .logo-icon {
      width: 40px;
      height: 40px;
    }
    .nav-link {
      position: relative;
    }
    .nav-link::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      width: 0;
      height: 2px;
      background: #c70039;
      transition: width 0.3s ease;
    }
    .nav-link:hover::after { width: 100%; }

    /* Section eyebrow with side lines */
    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #c70039;
    }
    .eyebrow::before, .eyebrow::after {
      content: '';
      display: block;
      width: 32px;
      height: 2px;
      background: #c70039;
      border-radius: 2px;
    }

    /* Section title highlight */
    .title-highlight {
      position: relative;
      display: inline-block;
    }
    .title-highlight::after {
      content: '';
      position: absolute;
      bottom: 4px;
      left: 0;
      right: 0;
      height: 6px;
      background: rgba(199, 0, 57, 0.15);
      border-radius: 4px;
      z-index: -1;
    }

    /* Service cards */
    .service-card {
      position: relative;
      overflow: hidden;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .service-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, #c70039, #ff4d6d);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.3s ease;
    }
    .service-card:hover::before { transform: scaleX(1); }
    .service-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 24px 48px rgba(199, 0, 57, 0.12);
    }

    /* Services section background pattern */
    .services-bg {
      background-color: #f8f9fc;
      background-image: radial-gradient(circle, #c7003915 1px, transparent 1px);
      background-size: 28px 28px;
    }

    .value-card:hover { transform: scale(1.05); }
    .value-card { transition: transform 0.3s ease; }

    /* Language switcher */
    .lang-dropdown { display: none; }
    .lang-dropdown.open { display: block; }
    .lang-btn {
      display: flex; align-items: center; gap: 6px;
      padding: 6px 12px; border-radius: 8px;
      border: 1px solid #e5e7eb; font-size: 0.8125rem;
      font-weight: 500; color: #374151; cursor: pointer;
      background: white; transition: background 0.2s;
      white-space: nowrap;
    }
    .lang-btn:hover { background: #f9fafb; }
    .lang-chevron { transition: transform 0.2s; }
    .lang-chevron.rotated { transform: rotate(180deg); }
    .lang-option {
      display: flex; align-items: center; gap: 8px;
      width: 100%; padding: 8px 14px; font-size: 0.8125rem;
      background: none; border: none; cursor: pointer;
      text-align: left; transition: background 0.15s; white-space: nowrap;
    }
    .lang-option:hover { background: #f3f4f6; }
    .lang-option.active { font-weight: 600; color: #c70039; }

    .step-dot {
      width: 48px;
      height: 48px;
      background: #c70039;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: 700;
      font-size: 1.1rem;
      flex-shrink: 0;
    }
    .step-line {
      width: 2px;
      height: 40px;
      background: linear-gradient(to bottom, #c70039, #E8003A88);
      margin-left: 23px;
    }

    #mobile-menu { display: none; }
    #mobile-menu.open { display: block; }

    .fade-in {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .btn-primary {
      background: #c70039;
      color: white;
      padding: 0.75rem 2rem;
      border-radius: 6px;
      font-weight: 600;
      transition: background 0.2s ease, transform 0.2s ease;
      display: inline-block;
      text-decoration: none;
    }
    .btn-primary:hover {
      background: #9e002e;
      transform: translateY(-1px);
    }
    .btn-outline {
      border: 2px solid white;
      color: white;
      padding: 0.75rem 2rem;
      border-radius: 6px;
      font-weight: 600;
      transition: background 0.2s ease, color 0.2s ease;
      display: inline-block;
      text-decoration: none;
    }
    .btn-outline:hover {
      background: white;
      color: #c70039;
    }


    /* ── News Modal ── */
    #news-modal {
      display: none; position: fixed; inset: 0; z-index: 1000;
      align-items: center; justify-content: center;
      background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);
      padding: 1rem;
    }
    #news-modal.open { display: flex; }
    #news-modal-box {
      background: white; border-radius: 1.25rem;
      max-width: 560px; width: 100%;
      max-height: 90vh; overflow-y: auto;
      box-shadow: 0 32px 64px rgba(0,0,0,0.25);
      animation: modalIn 0.25s ease;
    }
    @keyframes modalIn {
      from { opacity:0; transform: translateY(20px) scale(0.97); }
      to   { opacity:1; transform: translateY(0) scale(1); }
    }
    #news-modal-cover {
      height: 280px; display: flex; align-items: center; justify-content: center;
      border-radius: 1.25rem 1.25rem 0 0; flex-direction: column; gap: 1rem;
    }
    #news-modal-photo {
      width: 200px; height: 200px; border-radius: 50%;
      object-fit: cover; border: 5px solid white;
      box-shadow: 0 8px 24px rgba(0,0,0,0.3);
    }
    #news-modal-photo.logo {
      width: 300px; height: 180px; border-radius: 16px;
      object-fit: contain; border: none; background: white;
      padding: 24px; box-shadow: 0 8px 24px rgba(0,0,0,0.25);
    }
    #news-modal-avatar {
      width: 200px; height: 200px; border-radius: 50%;
      background: rgba(255,255,255,0.25);
      display: flex; align-items: center; justify-content: center;
      font-size: 4rem; font-weight: 800; color: white;
      border: 5px solid rgba(255,255,255,0.5);
    }

    input, textarea {
      outline: none;
    }
    input:focus, textarea:focus {
      box-shadow: 0 0 0 3px rgba(200, 0, 45, 0.2);
      border-color: #c70039 !important;
    }
  </style>
</head>
