  <!-- ===================== SCRIPTS ===================== -->
  <script>
    // ── i18n via external JSON ─────────────────────────────────────────
    let currentLang = localStorage.getItem('lang') || 'fr';
    let i18nDict = {};

    function applyDict(dict) {
      i18nDict = dict;
      document.querySelectorAll('[data-i18n]').forEach(el => {
        if (dict[el.dataset.i18n] !== undefined) el.textContent = dict[el.dataset.i18n];
      });
      document.querySelectorAll('[data-i18n-html]').forEach(el => {
        if (dict[el.dataset.i18nHtml] !== undefined) el.innerHTML = dict[el.dataset.i18nHtml];
      });
      document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
        if (dict[el.dataset.i18nPlaceholder] !== undefined) el.placeholder = dict[el.dataset.i18nPlaceholder];
      });
      const flag  = currentLang === 'fr' ? '🇫🇷' : '🇬🇧';
      const label = currentLang === 'fr' ? 'Français' : 'English';
      ['lang-flag','lang-flag-mobile'].forEach(id => { const el=document.getElementById(id); if(el) el.textContent=flag; });
      const lbl = document.getElementById('lang-label'); if(lbl) lbl.textContent=label;
      ['opt-fr','opt-en'].forEach(id => { const el=document.getElementById(id); if(el) el.classList.toggle('active', id===`opt-${currentLang}`); });
      document.documentElement.lang = currentLang;
    }

    async function loadLang(lang) {
      try {
        const res = await fetch(`/assets/i18n/${lang}.json`);
        if (!res.ok) throw new Error(res.status);
        const dict = await res.json();
        currentLang = lang;
        localStorage.setItem('lang', lang);
        applyDict(dict);
      } catch(e) {
        console.error('i18n load error:', e);
      }
    }

    function toggleLangMenu() {
      const dd = document.getElementById('lang-dropdown');
      const ch = document.getElementById('lang-chevron');
      dd.classList.toggle('open');
      ch.classList.toggle('rotated');
      document.addEventListener('click', closeLangOnOutside, { once: true });
    }
    function toggleLangMenuMobile() {
      const dd = document.getElementById('lang-dropdown-mobile');
      const ch = document.getElementById('lang-chevron-mobile');
      dd.classList.toggle('open');
      ch.classList.toggle('rotated');
      document.addEventListener('click', closeLangOnOutside, { once: true });
    }
    function closeLangOnOutside(e) {
      ['lang-dropdown','lang-dropdown-mobile'].forEach(id => {
        const dd = document.getElementById(id);
        if (dd && !dd.closest?.('#lang-switcher, #lang-switcher-mobile')?.contains(e.target)) {
          dd.classList.remove('open');
        }
      });
    }
    function setLang(lang) {
      loadLang(lang);
      ['lang-dropdown','lang-dropdown-mobile'].forEach(id => document.getElementById(id)?.classList.remove('open'));
      ['lang-chevron','lang-chevron-mobile'].forEach(id => document.getElementById(id)?.classList.remove('rotated'));
    }

    // Load default language on startup
    loadLang(currentLang);



    // ── News Modal ───────────────────────────────────────────────────────────
    const personArticles = {"a1": {"initials": "AI", "gradient": "linear-gradient(135deg,#c70039,#8b0025)", "label": "Fondateur Move2Cloud"}, "a2": {"initials": "DT", "gradient": "linear-gradient(135deg,#6d28d9,#4c1d95)", "label": "\u00c9quipe Move2Cloud"}, "a3": {"initials": "IK", "gradient": "linear-gradient(135deg,#0f766e,#134e4a)", "label": "\u00c9quipe Move2Cloud"}, "a8": {"initials": "SL", "gradient": "linear-gradient(135deg,#be185d,#831843)", "label": "\u00c9quipe Move2Cloud"}, "a13": {"initials": "SB", "gradient": "linear-gradient(135deg,#0891b2,#164e63)", "label": "\u00c9quipe Move2Cloud"}, "a14": {"initials": "IB", "gradient": "linear-gradient(135deg,#7c3aed,#4c1d95)", "label": "\u00c9quipe Move2Cloud"}};

    function openModal(key) {
      const dict = i18nDict;
      const modal = document.getElementById('news-modal');
      const cover = document.getElementById('news-modal-cover');
      const photo = document.getElementById('news-modal-photo');
      const avatar = document.getElementById('news-modal-avatar');
      const label = document.getElementById('news-modal-label');

      document.getElementById('news-modal-title').textContent = dict[`news.${key}.title`] || '';
      document.getElementById('news-modal-desc').textContent  = dict[`news.${key}.full`]  || dict[`news.${key}.desc`] || '';
      document.getElementById('news-modal-date').textContent  = dict[`news.${key}.date`]  || '';

      // Find tag text from any matching tag key
      const tagEl = document.querySelector(`[data-i18n="news.${key}.title"]`)?.closest('article')?.querySelector('[class*="font-semibold text-primary"]');
      document.getElementById('news-modal-tag').textContent = tagEl ? tagEl.textContent : '';

      // Cover — person or default
      const person = personArticles[key];
      const photoUrl = dict[`news.${key}.photo`] || '';

      if (photoUrl) {
        photo.alt = dict[`news.${key}.title`] || '';
        cover.style.background = person ? person.gradient : 'linear-gradient(135deg,#1a1a2e,#16213e)';
        label.textContent = '';
        // Try loading — fall back to initials if file missing
        const isLogo = !person;
        const img = new Image();
        img.onload = () => {
          photo.src = photoUrl;
          photo.style.display = 'block';
          avatar.style.display = 'none';
          photo.classList.toggle('logo', isLogo);
        };
        img.onerror = () => {
          photo.style.display = 'none';
          if (person) { avatar.style.display = 'flex'; avatar.textContent = person.initials; label.textContent = person.label; }
        };
        img.src = photoUrl;
      } else if (person) {
        photo.style.display = 'none'; avatar.style.display = 'flex';
        avatar.textContent = person.initials;
        label.textContent = person.label;
        cover.style.background = person.gradient;
      } else {
        photo.style.display = 'none'; avatar.style.display = 'none';
        label.textContent = '';
        // reuse the article card cover gradient
        const articleCover = document.querySelector(`[data-i18n="news.${key}.title"]`)?.closest('article')?.querySelector('[style*="background"]');
        cover.style.background = articleCover ? articleCover.style.background : 'linear-gradient(135deg,#c70039,#8b0025)';
      }

      modal.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      document.getElementById('news-modal').classList.remove('open');
      document.body.style.overflow = '';
    }

    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });


    // Scroll top on load
    window.scrollTo(0,0);

        // ── Mobile menu
    const burger = document.getElementById('burger');
    const mobileMenu = document.getElementById('mobile-menu');
    burger.addEventListener('click', () => mobileMenu.classList.toggle('open'));
    mobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => mobileMenu.classList.remove('open')));

    // Scroll-based fade-in
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

  </script>

