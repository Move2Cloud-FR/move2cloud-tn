<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Notre Approche — Move2Cloud Tunisie</title>
  <meta name="description" content="Découvrez notre approche de migration cloud en 5 étapes : du premier rendez-vous au support continu." />
  <link rel="canonical" href="https://move2cloud.tn/approach" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://move2cloud.tn/approach" />
  <meta property="og:title" content="Notre Approche — Move2Cloud Tunisie" />
  <meta property="og:image" content="https://move2cloud.tn/assets/preview.png" />
  <meta property="og:site_name" content="Move2Cloud Tunisie" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://move2cloud.tn/assets/preview.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="assets/favicon.svg" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#c70039',
            'primary-dark': '#9e002e',
            'primary-light': '#e8003a',
          },
          fontFamily: { poppins: ['Poppins', 'sans-serif'] },
        },
      },
    }
  </script>
  <style>
    * { font-family: 'Poppins', sans-serif; }
    html { scroll-behavior: smooth; }
    ::selection { background: #c70039; color: white; }

    .logo-icon { width: 40px; height: 40px; }
    .nav-link { position: relative; }
    .nav-link::after {
      content: ''; position: absolute; bottom: -2px; left: 0;
      width: 0; height: 2px; background: #c70039; transition: width 0.3s ease;
    }
    .nav-link:hover::after { width: 100%; }

    .eyebrow {
      display: inline-flex; align-items: center; gap: 0.75rem;
      font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em;
      text-transform: uppercase; color: #c70039;
    }
    .eyebrow::before, .eyebrow::after {
      content: ''; display: block; width: 32px; height: 2px;
      background: #c70039; border-radius: 2px;
    }

    .step-dot {
      width: 48px; height: 48px; background: #c70039; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      color: white; font-weight: 700; font-size: 1.1rem; flex-shrink: 0;
    }
    .step-line {
      width: 2px; height: 40px;
      background: linear-gradient(to bottom, #c70039, #E8003A88);
      margin-left: 23px;
    }

    /* Language switcher */
    .lang-dropdown { display: none; }
    .lang-dropdown.open { display: block; }
    .lang-btn {
      display: flex; align-items: center; gap: 6px;
      padding: 6px 12px; border-radius: 8px;
      border: 1px solid #e5e7eb; font-size: 0.8125rem;
      font-weight: 500; color: #374151; cursor: pointer;
      background: white; transition: background 0.2s; white-space: nowrap;
    }
    .lang-btn:hover { background: #f9fafb; }
    .lang-chevron { transition: transform 0.2s; }
    .lang-chevron.rotated { transform: rotate(180deg); }
    .lang-option {
      display: flex; align-items: center; gap: 8px;
      width: 100%; padding: 8px 14px; font-size: 0.8125rem;
      background: none; border: none; cursor: pointer;
      text-align: left; transition: background 0.15s; white-space: nowrap;
    }
    .lang-option:hover { background: #f3f4f6; }
    .lang-option.active { font-weight: 600; color: #c70039; }

    #mobile-menu { display: none; }
    #mobile-menu.open { display: block; }

    .btn-primary {
      background: #c70039; color: white; padding: 0.75rem 2rem;
      border-radius: 6px; font-weight: 600; transition: background 0.2s ease, transform 0.2s ease;
      display: inline-block; text-decoration: none;
    }
    .btn-primary:hover { background: #9e002e; transform: translateY(-1px); }

    .fade-in { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .fade-in.visible { opacity: 1; transform: translateY(0); }
  </style>
</head>
<body class="bg-white text-gray-800">

<%- include('partials/header', {currentPage: 'approach'}) %>

  <!-- ===================== PROCESS ===================== -->
  <section class="py-24 bg-white pt-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div class="fade-in">
          <span class="eyebrow" data-i18n="proc.eyebrow">Comment ça marche</span>
          <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mt-3 mb-4" data-i18n-html="proc.title">Notre approche<br/>de migration cloud</h1>
          <p class="text-gray-500 leading-relaxed mb-2" data-i18n="proc.desc">Migrer vers le cloud est un défi de taille, mais nous sommes là pour vous accompagner à chaque étape. Notre équipe d'experts travaillera avec vous pour évaluer votre infrastructure actuelle, identifier vos objectifs et élaborer une stratégie sur mesure.</p>
          <div class="mt-8">
            <a href="/contact" class="btn-primary">Démarrer votre projet</a>
          </div>
        </div>

        <div class="space-y-0 fade-in">
          <!-- Step 1 -->
          <div class="flex gap-4">
            <div class="flex flex-col items-center">
              <div class="step-dot">1</div>
              <div class="step-line"></div>
            </div>
            <div class="pb-8 pt-2">
              <h3 class="font-semibold text-gray-900 mb-1" data-i18n="step1.title">Premier rendez-vous</h3>
              <p class="text-gray-500 text-sm" data-i18n="step1.desc">Vous nous parlez de votre entreprise, vos besoins et vos objectifs de transformation digitale.</p>
            </div>
          </div>
          <!-- Step 2 -->
          <div class="flex gap-4">
            <div class="flex flex-col items-center">
              <div class="step-dot">2</div>
              <div class="step-line"></div>
            </div>
            <div class="pb-8 pt-2">
              <h3 class="font-semibold text-gray-900 mb-1" data-i18n="step2.title">Proposition sur mesure</h3>
              <p class="text-gray-500 text-sm" data-i18n="step2.desc">Nous revenons vers vous avec une solution adaptée à vos besoins spécifiques et à votre budget.</p>
            </div>
          </div>
          <!-- Step 3 -->
          <div class="flex gap-4">
            <div class="flex flex-col items-center">
              <div class="step-dot">3</div>
              <div class="step-line"></div>
            </div>
            <div class="pb-8 pt-2">
              <h3 class="font-semibold text-gray-900 mb-1" data-i18n="step3.title">Mise en œuvre</h3>
              <p class="text-gray-500 text-sm" data-i18n="step3.desc">Une fois la solution convenue, nous nous mettons au travail pour implémenter votre système cloud.</p>
            </div>
          </div>
          <!-- Step 4 -->
          <div class="flex gap-4">
            <div class="flex flex-col items-center">
              <div class="step-dot">4</div>
              <div class="step-line"></div>
            </div>
            <div class="pb-8 pt-2">
              <h3 class="font-semibold text-gray-900 mb-1" data-i18n="step4.title">Intégration sécurisée</h3>
              <p class="text-gray-500 text-sm" data-i18n="step4.desc">Intégration transparente et sécurisée de vos processus métier existants dans le nouvel environnement.</p>
            </div>
          </div>
          <!-- Step 5 -->
          <div class="flex gap-4">
            <div class="flex flex-col items-center">
              <div class="step-dot">5</div>
            </div>
            <div class="pt-2">
              <h3 class="font-semibold text-gray-900 mb-1" data-i18n="step5.title">Support continu</h3>
              <p class="text-gray-500 text-sm" data-i18n="step5.desc">Nous restons à vos côtés avec un support technique continu pour assurer la pérennité de votre infrastructure.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

<%- include('partials/footer') %>

<script>
  // Burger menu
  document.getElementById('burger').addEventListener('click', () =>
    document.getElementById('mobile-menu').classList.toggle('open'));

  // Lang switcher
  function toggleLangMenu() {
    document.getElementById('lang-dropdown').classList.toggle('open');
    document.getElementById('lang-chevron').classList.toggle('rotated');
  }
  document.addEventListener('click', e => {
    if (!document.getElementById('lang-switcher').contains(e.target)) {
      document.getElementById('lang-dropdown').classList.remove('open');
      document.getElementById('lang-chevron').classList.remove('rotated');
    }
  });

  let currentLang = localStorage.getItem('lang') || 'fr';
  const TRANSLATIONS = {};

  async function loadLang(lang) {
    if (!TRANSLATIONS[lang]) {
      try {
        const res = await fetch(`/assets/i18n/${lang}.json`);
        TRANSLATIONS[lang] = await res.json();
      } catch(e) { TRANSLATIONS[lang] = {}; }
    }
    currentLang = lang; localStorage.setItem('lang', lang);
    const dict = TRANSLATIONS[lang] || {};
    document.querySelectorAll('[data-i18n]').forEach(el => {
      if (dict[el.dataset.i18n] !== undefined) el.textContent = dict[el.dataset.i18n];
    });
    document.querySelectorAll('[data-i18n-html]').forEach(el => {
      if (dict[el.dataset.i18nHtml] !== undefined) el.innerHTML = dict[el.dataset.i18nHtml];
    });
    const isEN = lang === 'en';
    document.getElementById('lang-flag').textContent = isEN ? '🇬🇧' : '🇫🇷';
    document.getElementById('lang-label').textContent = isEN ? 'English' : 'Français';
    document.getElementById('opt-fr').classList.toggle('active', !isEN);
    document.getElementById('opt-en').classList.toggle('active', isEN);
    document.documentElement.lang = lang;
  }
  function setLang(lang) {
    loadLang(lang);
    document.getElementById('lang-dropdown').classList.remove('open');
    document.getElementById('lang-chevron').classList.remove('rotated');
  }
  loadLang(currentLang);

  // Scroll-based fade-in
  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) { entry.target.classList.add('visible'); observer.unobserve(entry.target); }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
</script>
</body>
</html>
