  <script>
    document.getElementById('burger').addEventListener('click', () => document.getElementById('mobile-menu').classList.toggle('open'));
    function toggleLangMenu() {
      document.getElementById('lang-dropdown').classList.toggle('open');
      document.getElementById('lang-chevron').classList.toggle('rotated');
    }
    document.addEventListener('click', e => {
      if (!document.getElementById('lang-switcher').contains(e.target))
        document.getElementById('lang-dropdown').classList.remove('open');
    });
    const TRANSLATIONS = {};
    let currentLang = localStorage.getItem('lang') || 'fr';
    
    // Extended i18n: swap data-en / data-fr attributes
    function applyInlineTranslations(lang) {
      document.querySelectorAll('[data-en]').forEach(el => {
        if (!el.dataset.fr) el.dataset.fr = el.innerHTML;
        el.innerHTML = lang === 'en' ? el.dataset.en : el.dataset.fr;
      });
      document.querySelectorAll('[data-en-placeholder],[data-fr-placeholder]').forEach(el => {
        if (!el.dataset.frPlaceholder) el.dataset.frPlaceholder = el.placeholder;
        el.placeholder = lang === 'en' ? el.dataset.enPlaceholder : el.dataset.frPlaceholder;
      });
    }
        function loadLang(lang) {
      const slug = window.location.pathname.split('/').pop().replace('.html', '') || 'index';
      Promise.all([
        fetch('../assets/i18n/' + lang + '.json').then(r => r.json()),
        fetch('../assets/i18n/jobs/' + slug + '.' + lang + '.json').then(r => r.json()).catch(() => ({}))
      ]).then(function(results) {
        var mainDict = results[0], jobDict = results[1];
        var dict = Object.assign({}, mainDict, jobDict);
        document.querySelectorAll('[data-i18n]').forEach(function(el) {
          var val = dict[el.dataset.i18n];
          if (val !== undefined) {
            el.innerHTML = Array.isArray(val) ? val.join(' · ') : val;
          }
        });
        applyInlineTranslations(lang);
        document.getElementById('opt-fr').classList.toggle('active', lang === 'fr');
        document.getElementById('opt-en').classList.toggle('active', lang === 'en');
        localStorage.setItem('lang', lang);
        currentLang = lang;
        var isEN = lang === 'en';
        document.getElementById('lang-flag').textContent = isEN ? '🇬🇧' : '🇫🇷';
        document.getElementById('lang-label').textContent = isEN ? 'English' : 'Français';
      });
    }
    function setLang(lang) { loadLang(lang); document.getElementById('lang-dropdown').classList.remove('open'); }
    loadLang(currentLang);

    emailjs.init('vUJW1aDvhHR4GjOX8');
    function onCvChange(input) {
      const file = input.files[0];
      if (file && file.size > 500 * 1024) {
        document.getElementById('cv-error').classList.remove('hidden');
        input.value = ''; document.getElementById('cv-name').textContent = 'Choisir un fichier';
      } else {
        document.getElementById('cv-error').classList.add('hidden');
        document.getElementById('cv-name').textContent = file ? file.name : 'Choisir un fichier';
      }
    }
    async function submitForm() {
      const errEl = document.getElementById('form-error');
      errEl.classList.add('hidden');
      const firstName = document.getElementById('f-firstName').value.trim();
      const lastName  = document.getElementById('f-lastName').value.trim();
      const email     = document.getElementById('f-email').value.trim();
      const phone     = document.getElementById('f-phone').value.trim();
      const rgpd      = document.getElementById('f-rgpd').checked;
      const cvInput   = document.getElementById('f-cv');
      if (!firstName || !lastName) { errEl.textContent = 'Veuillez saisir votre prénom et votre nom.'; errEl.classList.remove('hidden'); return; }
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { errEl.textContent = 'Adresse email invalide.'; errEl.classList.remove('hidden'); return; }
      if (!phone) { errEl.textContent = 'Veuillez saisir votre numéro de téléphone.'; errEl.classList.remove('hidden'); return; }
      if (!cvInput.files.length) { errEl.textContent = 'Veuillez joindre votre CV.'; errEl.classList.remove('hidden'); return; }
      if (!rgpd) { errEl.textContent = 'Veuillez accepter la politique de confidentialité.'; errEl.classList.remove('hidden'); return; }
      const btn = document.getElementById('submit-btn');
      document.getElementById('submit-label').textContent = 'Envoi en cours…';
      document.getElementById('submit-spinner').classList.remove('hidden');
      btn.disabled = true;
      try {
        await emailjs.sendForm('service_rqwhxgi', 'template_3cwgv1p', document.getElementById('apply-form'));
        document.getElementById('apply-form').classList.add('hidden');
        document.getElementById('form-success').classList.remove('hidden');
      } catch (err) {
        errEl.textContent = 'Une erreur est survenue. Envoyez votre CV à recrutement@move2cloud.tn';
        errEl.classList.remove('hidden');
        document.getElementById('submit-label').textContent = 'Postuler';
        document.getElementById('submit-spinner').classList.add('hidden');
        btn.disabled = false;
      }
    }
  </script>
</body>
</html>