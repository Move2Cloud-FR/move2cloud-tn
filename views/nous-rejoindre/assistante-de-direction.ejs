  <meta name="description" content="Offre d'emploi CDI — Assistante de Direction à Tunis. Rejoignez Move2Cloud Tunisie." />
  <link rel="canonical" href="https://move2cloud.tn/nous-rejoindre/assistante-de-direction" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Assistante de Direction — Move2Cloud Tunisie" />
  <meta property="og:image" content="https://move2cloud.tn/assets/preview.png" />
  <meta property="og:site_name" content="Move2Cloud Tunisie" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="../assets/favicon.svg" />
  <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#c70039',
            'primary-dark': '#9e002e',
          },
        },
      },
    }
  </script>
  <style>
    * { font-family: 'Poppins', sans-serif; }
    html { scroll-behavior: smooth; }

    .logo-icon { width: 40px; height: 40px; }

    .nav-link { position: relative; }
    .nav-link::after {
      content: ''; position: absolute; bottom: -2px; left: 0;
      width: 0; height: 2px; background: #c70039; transition: width 0.3s ease;
    }
    .nav-link:hover::after { width: 100%; }

    .btn-primary {
      background: #c70039; color: white; padding: 0.75rem 2rem;
      border-radius: 6px; font-weight: 600; font-size: 0.875rem;
      transition: background 0.2s ease, transform 0.2s ease;
      display: inline-block; text-decoration: none;
    }
    .btn-primary:hover { background: #9e002e; transform: translateY(-1px); }

    .btn-outline {
      border: 2px solid #c70039; color: #c70039; padding: 0.65rem 1.75rem;
      border-radius: 6px; font-weight: 600; font-size: 0.875rem;
      transition: all 0.2s ease; display: inline-block; text-decoration: none;
    }
    .btn-outline:hover { background: #c70039; color: white; }

    .badge {
      display: inline-flex; align-items: center; gap: 4px;
      padding: 4px 12px; border-radius: 999px;
      font-size: 0.75rem; font-weight: 600;
    }
    .badge-cdi    { background: #dcfce7; color: #15803d; }
    .badge-location { background: #f1f5f9; color: #475569; }
    .badge-sector { background: #fff7ed; color: #c2410c; }

    .section-card {
      border: 1px solid #e5e7eb;
      border-radius: 1rem;
      padding: 1.5rem;
    }

    .check-item {
      display: flex; gap: 0.75rem; align-items: flex-start;
      font-size: 0.875rem; color: #374151; line-height: 1.6;
    }
    .check-icon { color: #c70039; font-weight: 700; margin-top: 2px; flex-shrink: 0; }

    #mobile-menu { display: none; }
    #mobile-menu.open { display: block; }

    .lang-dropdown { display: none; }
    .lang-dropdown.open { display: block; }
    .lang-btn {
      display: flex; align-items: center; gap: 6px; padding: 6px 12px;
      border-radius: 8px; border: 1px solid #e5e7eb; font-size: 0.8125rem;
      font-weight: 500; color: #374151; cursor: pointer; background: white;
      transition: background 0.2s;
    }
    .lang-btn:hover { background: #f9fafb; }
    .lang-chevron { transition: transform 0.2s; }
    .lang-chevron.rotated { transform: rotate(180deg); }
    .lang-option {
      display: flex; align-items: center; gap: 8px; width: 100%;
      padding: 8px 14px; font-size: 0.8125rem; background: none;
      border: none; cursor: pointer; text-align: left; transition: background 0.15s;
    }
    .lang-option:hover { background: #f3f4f6; }
    .lang-option.active { font-weight: 600; color: #c70039; }
  </style>
</head>
<body class="bg-white text-gray-800">

