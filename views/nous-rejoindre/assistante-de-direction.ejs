  <!-- ── FORMULAIRE CANDIDATURE ── -->
  <section id="postuler" class="bg-gray-50 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto rounded-2xl overflow-hidden shadow-2xl" style="background:#c70039;">
        <div class="px-8 sm:px-12 py-10">

          <p class="text-red-200 text-xs font-semibold uppercase tracking-widest mb-4"><span data-i18n="form.eyebrow">/ Nous rejoindre /</span></p>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-white leading-tight mb-8">
            <span data-i18n="form.title">Déposez votre candidature pour rejoindre nos équipes et relever nos défis&nbsp;!
          </span></h2>

          <form id="apply-form" novalidate class="space-y-5">

            <!-- Prénom + Nom -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <input type="text" id="f-firstName" name="firstName" required
                placeholder="Prénom *" data-en-placeholder="First name *" data-fr-placeholder="Prénom *"
                class="w-full bg-white border border-gray-200 rounded-lg text-gray-800 placeholder-gray-400
                       px-4 py-3 text-sm focus:outline-none focus:border-red-400 transition-colors" />
              <input type="text" id="f-lastName" name="lastName" required
                placeholder="Nom *" data-en-placeholder="Last name *" data-fr-placeholder="Nom *"
                class="w-full bg-white border border-gray-200 rounded-lg text-gray-800 placeholder-gray-400
                       px-4 py-3 text-sm focus:outline-none focus:border-red-400 transition-colors" />
            </div>

            <!-- Email + Téléphone -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <input type="email" id="f-email" name="email" required
                placeholder="Email *" data-en-placeholder="Email *" data-fr-placeholder="Email *"
                class="w-full bg-white border border-gray-200 rounded-lg text-gray-800 placeholder-gray-400
                       px-4 py-3 text-sm focus:outline-none focus:border-red-400 transition-colors" />
              <input type="tel" id="f-phone" name="phone" required
                placeholder="Téléphone *" data-en-placeholder="Phone *" data-fr-placeholder="Téléphone *"
                class="w-full bg-white border border-gray-200 rounded-lg text-gray-800 placeholder-gray-400
                       px-4 py-3 text-sm focus:outline-none focus:border-red-400 transition-colors" />
            </div>

            <!-- Informations complémentaires -->
            <input type="text" id="f-additionalInfos" name="additionalInfos"
              placeholder="Profil LinkedIn (optionnel)"
              class="w-full bg-white border border-gray-200 rounded-lg text-gray-800 placeholder-gray-400
                     px-4 py-3 text-sm focus:outline-none focus:border-red-400 transition-colors" />

            <!-- CV upload -->
            <div>
              <label class="flex items-center gap-3 cursor-pointer rounded-lg px-4 py-3
                            hover:opacity-90 transition-opacity mt-2" style="background:#0d1117;">
                <svg class="w-5 h-5 shrink-0" fill="none" stroke="white" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/>
                </svg>
                <span id="cv-name" class="text-white text-sm"><span data-i18n="form.cv">Choisir un fichier (CV — max 500 Ko)</span>
                <input type="file" id="f-cv" name="file" accept=".pdf,.doc,.docx" class="hidden"
                  onchange="onCvChange(this)" />
              </label>
              <p id="cv-error" class="hidden text-white text-xs mt-1 font-medium"><span data-i18n="form.cv.error">Le fichier dépasse 500 Ko.</span></p>
            </div>

            <!-- RGPD -->
            <div class="flex items-start gap-3 pt-1">
              <input type="checkbox" id="f-rgpd" class="w-4 h-4 cursor-pointer mt-0.5 shrink-0" />
              <label for="f-rgpd" class="text-xs text-white/80 leading-relaxed cursor-pointer">
                En soumettant ce formulaire, j'accepte que mes données personnelles soient utilisées
                pour le traitement de ma candidature par Move2Cloud Tunisie, conformément à notre
                politique de confidentialité.
              </label>
            </div>

            <!-- Message d'erreur global -->
            <p id="form-error" class="hidden text-yellow-200 text-xs font-medium"></p>

            <!-- Submit -->
            <button type="button" onclick="submitForm()" id="submit-btn"
              class="w-full bg-white text-gray-900 font-bold py-4 rounded-full text-sm
                     hover:bg-gray-100 active:scale-[0.99] transition-all flex items-center justify-center gap-2">
              <span id="submit-label" data-i18n="form.submit">Postuler</span>
              <svg id="submit-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
              </svg>
            </button>

          </form>

          <!-- Confirmation — hors du form pour rester visible après masquage -->
          <div id="form-success" class="hidden text-center py-8">
            <div class="text-4xl mb-3">✅</div>
            <p class="text-white text-lg font-semibold"><span data-i18n="form.success.title">Candidature envoyée !</span></p>
            <p class="text-white/70 text-sm mt-2"><span data-i18n="form.success.desc">Nous reviendrons vers vous dans les meilleurs délais.</span></p>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ── FOOTER ── -->
<%- include('../partials/footer') %>

  <script>
    // Burger
    document.getElementById('burger').addEventListener('click', () => {
      document.getElementById('mobile-menu').classList.toggle('open');
    });

    // Lang menu
    function toggleLangMenu() {
      document.getElementById('lang-dropdown').classList.toggle('open');
      document.getElementById('lang-chevron').classList.toggle('rotated');
    }
    document.addEventListener('click', e => {
      if (!document.getElementById('lang-switcher').contains(e.target))
        document.getElementById('lang-dropdown').classList.remove('open');
    });

    // i18n (minimal)
    const TRANSLATIONS = {};
    let currentLang = localStorage.getItem('lang') || 'fr';
    
    // Extended i18n: swap data-en / data-fr attributes
    function applyInlineTranslations(lang) {
      document.querySelectorAll('[data-en]').forEach(el => {
        if (!el.dataset.fr) el.dataset.fr = el.innerHTML;
        el.innerHTML = lang === 'en' ? el.dataset.en : el.dataset.fr;
      });
      document.querySelectorAll('[data-en-placeholder],[data-fr-placeholder]').forEach(el => {
        if (!el.dataset.frPlaceholder) el.dataset.frPlaceholder = el.placeholder;
        el.placeholder = lang === 'en' ? el.dataset.enPlaceholder : el.dataset.frPlaceholder;
      });
    }
    function loadLang(lang) {
      const slug = window.location.pathname.split('/').pop().replace('.html', '') || 'index';
      Promise.all([
        fetch('../assets/i18n/' + lang + '.json').then(r => r.json()),
        fetch('../assets/i18n/jobs/' + slug + '.' + lang + '.json').then(r => r.json()).catch(() => ({}))
      ]).then(function(results) {
        var mainDict = results[0], jobDict = results[1];
        var dict = Object.assign({}, mainDict, jobDict);
        document.querySelectorAll('[data-i18n]').forEach(function(el) {
          var val = dict[el.dataset.i18n];
          if (val !== undefined) {
            el.innerHTML = Array.isArray(val) ? val.join(' · ') : val;
          }
        });
        applyInlineTranslations(lang);
        document.getElementById('opt-fr').classList.toggle('active', lang === 'fr');
        document.getElementById('opt-en').classList.toggle('active', lang === 'en');
        localStorage.setItem('lang', lang);
        currentLang = lang;
        var isEN = lang === 'en';
        document.getElementById('lang-flag').textContent = isEN ? '🇬🇧' : '🇫🇷';
        document.getElementById('lang-label').textContent = isEN ? 'English' : 'Français';
      });
    }
    function setLang(lang) {
      loadLang(lang);
      document.getElementById('lang-dropdown').classList.remove('open');
    }
    loadLang(currentLang);

    // ── EmailJS
    emailjs.init('vUJW1aDvhHR4GjOX8');

    function onCvChange(input) {
      const file = input.files[0];
      const errEl = document.getElementById('cv-error');
      if (file && file.size > 500 * 1024) {
        errEl.classList.remove('hidden');
        input.value = '';
        document.getElementById('cv-name').textContent = 'Choisir un fichier';
      } else {
        errEl.classList.add('hidden');
        document.getElementById('cv-name').textContent = file ? file.name : 'Choisir un fichier';
      }
    }

    async function submitForm() {
      const errEl = document.getElementById('form-error');
      errEl.classList.add('hidden');

      const firstName = document.getElementById('f-firstName').value.trim();
      const lastName  = document.getElementById('f-lastName').value.trim();
      const email     = document.getElementById('f-email').value.trim();
      const phone     = document.getElementById('f-phone').value.trim();
      const rgpd      = document.getElementById('f-rgpd').checked;
      const cvInput   = document.getElementById('f-cv');

      // Validation
      if (!firstName || !lastName) {
        errEl.textContent = 'Veuillez saisir votre prénom et votre nom.';
        errEl.classList.remove('hidden'); return;
      }
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        errEl.textContent = 'Adresse email invalide.';
        errEl.classList.remove('hidden'); return;
      }
      if (!phone) {
        errEl.textContent = 'Veuillez saisir votre numéro de téléphone.';
        errEl.classList.remove('hidden'); return;
      }
      if (!cvInput.files.length) {
        errEl.textContent = 'Veuillez joindre votre CV.';
        errEl.classList.remove('hidden'); return;
      }
      if (!rgpd) {
        errEl.textContent = 'Veuillez accepter la politique de confidentialité.';
        errEl.classList.remove('hidden'); return;
      }

      // Spinner
      const btn = document.getElementById('submit-btn');
      document.getElementById('submit-label').textContent = 'Envoi en cours…';
      document.getElementById('submit-spinner').classList.remove('hidden');
      btn.disabled = true;

      try {
        await emailjs.sendForm(
          'service_rqwhxgi',
          'template_3cwgv1p',
          document.getElementById('apply-form')
        );
        document.getElementById('apply-form').classList.add('hidden');
        document.getElementById('form-success').classList.remove('hidden');
      } catch (err) {
        errEl.textContent = 'Une erreur est survenue. Veuillez réessayer ou envoyer votre CV à recrutement@move2cloud.tn';
        errEl.classList.remove('hidden');
        document.getElementById('submit-label').textContent = 'Postuler';
        document.getElementById('submit-spinner').classList.add('hidden');
        btn.disabled = false;
      }
    }
  </script>
</body>
</html>
