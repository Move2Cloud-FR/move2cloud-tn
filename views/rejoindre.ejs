  <style>
    * { font-family: 'Poppins', sans-serif; }
    html { scroll-behavior: smooth; }

    .logo-icon { width: 40px; height: 40px; }
    .nav-link { position: relative; }
    .nav-link::after { content:''; position:absolute; bottom:-2px; left:0; width:0; height:2px; background:#c70039; transition:width 0.3s; }
    .nav-link:hover::after { width:100%; }

    .btn-primary { background:#c70039; color:white; padding:0.75rem 2rem; border-radius:6px; font-weight:600; font-size:0.875rem; transition:background 0.2s,transform 0.2s; display:inline-block; text-decoration:none; }
    .btn-primary:hover { background:#9e002e; transform:translateY(-1px); }

    .filter-btn {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 4px 12px; border-radius: 999px; font-size: 0.75rem; font-weight: 600;
      cursor: pointer; border: 1.5px solid #e5e7eb; background: white; color: #4b5563;
      transition: all 0.18s; white-space: nowrap; line-height: 1.5;
    }
    .filter-btn:hover { border-color: #c70039; color: #c70039; background: #fff5f7; }
    .filter-btn.active { background: #c70039; border-color: #c70039; color: white; }
    .filter-group-label {
      font-size: 0.62rem; font-weight: 700; letter-spacing: 0.1em;
      text-transform: uppercase; color: #9ca3af;
    }
    .filter-row {
      display: flex; align-items: center; gap: 0.5rem;
      overflow-x: auto; flex-wrap: nowrap;
      scrollbar-width: none; -ms-overflow-style: none;
      padding-bottom: 2px;
    }
    .filter-row::-webkit-scrollbar { display: none; }
    @media (min-width: 640px) {
      .filter-row { flex-wrap: wrap; justify-content: center; overflow-x: visible; }
    }

    .job-card {
      background: white; border: 1px solid #e5e7eb; border-radius: 1rem;
      padding: 1.5rem; display: flex; flex-direction: column; gap: 0.75rem;
      transition: transform 0.2s, box-shadow 0.2s; position: relative; overflow: hidden;
    }
    .job-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg,#c70039,#ff4d6d);
      transform: scaleX(0); transform-origin: left; transition: transform 0.25s;
    }
    .job-card:hover::before { transform: scaleX(1); }
    .job-card:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(199,0,57,0.1); }
    .job-card.hidden-card { display: none !important; }

    .badge { display:inline-flex; align-items:center; gap:3px; padding:3px 10px; border-radius:999px; font-size:0.7rem; font-weight:600; }
    .badge-cdi      { background:#dcfce7; color:#15803d; }
    .badge-alt      { background:#f3e8ff; color:#6b21a8; }
    .badge-location { background:#f1f5f9; color:#475569; }

    #empty-state { display: none; }
    #empty-state.visible { display: flex; }

    #mobile-menu { display:none; }
    #mobile-menu.open { display:block; }
    .lang-dropdown { display:none; }
    .lang-dropdown.open { display:block; }
    .lang-btn { display:flex; align-items:center; gap:6px; padding:6px 12px; border-radius:8px; border:1px solid #e5e7eb; font-size:0.8125rem; font-weight:500; color:#374151; cursor:pointer; background:white; }
    .lang-btn:hover { background:#f9fafb; }
    .lang-chevron { transition:transform 0.2s; }
    .lang-chevron.rotated { transform:rotate(180deg); }
    .lang-option { display:flex; align-items:center; gap:8px; width:100%; padding:8px 14px; font-size:0.8125rem; background:none; border:none; cursor:pointer; text-align:left; }
    .lang-option:hover { background:#f3f4f6; }
    .lang-option.active { font-weight:600; color:#c70039; }

    .eyebrow { display:inline-flex; align-items:center; gap:0.75rem; font-size:0.75rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#c70039; }
    .eyebrow::before,.eyebrow::after { content:''; display:block; width:32px; height:2px; background:#c70039; border-radius:2px; }
  </style>
