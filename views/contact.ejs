<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact — Move2Cloud Tunisie</title>
  <meta name="description" content="Contactez Move2Cloud Tunisie — experts Cloud & DevOps. Espace Tunis, Montplaisir 1073. Tél : +216 71 906 323." />
  <link rel="canonical" href="https://move2cloud.tn/contact" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://move2cloud.tn/contact" />
  <meta property="og:title" content="Contact — Move2Cloud Tunisie" />
  <meta property="og:image" content="https://move2cloud.tn/assets/preview.png" />
  <meta property="og:site_name" content="Move2Cloud Tunisie" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://move2cloud.tn/assets/preview.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="assets/favicon.svg" />
  <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#c70039',
            'primary-dark': '#9e002e',
            'primary-light': '#e8003a',
          },
          fontFamily: { poppins: ['Poppins', 'sans-serif'] },
        },
      },
    }
  </script>
  <style>
    * { font-family: 'Poppins', sans-serif; }
    html { scroll-behavior: smooth; }
    ::selection { background: #c70039; color: white; }

    .logo-icon { width: 40px; height: 40px; }
    .nav-link { position: relative; }
    .nav-link::after {
      content: ''; position: absolute; bottom: -2px; left: 0;
      width: 0; height: 2px; background: #c70039; transition: width 0.3s ease;
    }
    .nav-link:hover::after { width: 100%; }

    .eyebrow {
      display: inline-flex; align-items: center; gap: 0.75rem;
      font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em;
      text-transform: uppercase; color: #c70039;
    }
    .eyebrow::before, .eyebrow::after {
      content: ''; display: block; width: 32px; height: 2px;
      background: #c70039; border-radius: 2px;
    }

    .title-highlight { position: relative; display: inline-block; }
    .title-highlight::after {
      content: ''; position: absolute; bottom: 4px; left: 0; right: 0;
      height: 6px; background: rgba(199, 0, 57, 0.15); border-radius: 4px; z-index: -1;
    }

    /* Language switcher */
    .lang-dropdown { display: none; }
    .lang-dropdown.open { display: block; }
    .lang-btn {
      display: flex; align-items: center; gap: 6px;
      padding: 6px 12px; border-radius: 8px;
      border: 1px solid #e5e7eb; font-size: 0.8125rem;
      font-weight: 500; color: #374151; cursor: pointer;
      background: white; transition: background 0.2s; white-space: nowrap;
    }
    .lang-btn:hover { background: #f9fafb; }
    .lang-chevron { transition: transform 0.2s; }
    .lang-chevron.rotated { transform: rotate(180deg); }
    .lang-option {
      display: flex; align-items: center; gap: 8px;
      width: 100%; padding: 8px 14px; font-size: 0.8125rem;
      background: none; border: none; cursor: pointer;
      text-align: left; transition: background 0.15s; white-space: nowrap;
    }
    .lang-option:hover { background: #f3f4f6; }
    .lang-option.active { font-weight: 600; color: #c70039; }

    #mobile-menu { display: none; }
    #mobile-menu.open { display: block; }

    .btn-primary {
      background: #c70039; color: white; padding: 0.75rem 2rem;
      border-radius: 6px; font-weight: 600; transition: background 0.2s ease, transform 0.2s ease;
      display: inline-block; text-decoration: none;
    }
    .btn-primary:hover { background: #9e002e; transform: translateY(-1px); }

    input, textarea { outline: none; }
    input:focus, textarea:focus {
      box-shadow: 0 0 0 3px rgba(200, 0, 45, 0.2);
      border-color: #c70039 !important;
    }

    .fade-in { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .fade-in.visible { opacity: 1; transform: translateY(0); }
  </style>
</head>
<body class="bg-white text-gray-800">

<%- include('partials/header', {currentPage: 'contact'}) %>

  <!-- ===================== CONTACT ===================== -->
  <section class="py-24 bg-gray-50 pt-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 fade-in">
        <span class="eyebrow" data-i18n="contact.eyebrow">Parlons-en</span>
        <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mt-5" data-i18n-html="contact.title"><span class="title-highlight text-primary">Contactez</span>-nous</h1>
        <p class="text-gray-500 mt-4 max-w-xl mx-auto" data-i18n="contact.desc">Move2Cloud s'engage à répondre à vos questions et à satisfaire vos demandes dans les plus brefs délais.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <!-- Contact Info -->
        <div class="lg:col-span-2 space-y-6 fade-in">
          <div>
            <h3 class="font-semibold text-gray-900 text-lg mb-4" data-i18n="contact.info.title">Prenez contact avec nous</h3>
            <p class="text-gray-500 text-sm leading-relaxed" data-i18n="contact.info.desc">Nous vous accompagnons dans votre stratégie de transformation digitale pour répondre au mieux aux besoins du marché tunisien et international.</p>
          </div>

          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <div class="w-9 h-9 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg width="16" height="16" fill="none" stroke="#c70039" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <div class="font-medium text-gray-900 text-sm" data-i18n="contact.lbl.address">Adresse</div>
                <div class="text-gray-500 text-sm">Espace Tunis, bloc H, bureau H3-1<br/>Montplaisir 1073</div>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="w-9 h-9 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg width="16" height="16" fill="none" stroke="#c70039" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <div class="font-medium text-gray-900 text-sm" data-i18n="contact.lbl.email">Email</div>
                <a href="mailto:contact@move2cloud.tn" class="text-primary text-sm hover:underline">contact@move2cloud.tn</a>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="w-9 h-9 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg width="16" height="16" fill="none" stroke="#c70039" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <div class="font-medium text-gray-900 text-sm" data-i18n="contact.lbl.phone">Téléphone</div>
                <a href="tel:+21671906323" class="text-gray-500 text-sm hover:text-primary">+216 71 906 323</a>
              </div>
            </div>


            <div class="flex items-start gap-3">
              <div class="w-9 h-9 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#c70039">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </div>
              <div>
                <div class="font-medium text-gray-900 text-sm" data-i18n="contact.lbl.linkedin">LinkedIn</div>
                <a href="https://www.linkedin.com/company/movetocloud" target="_blank" rel="noopener" class="text-primary text-sm hover:underline">Move2Cloud</a>
              </div>
            </div>

            <div class="flex items-start gap-3">
              <div class="w-9 h-9 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg width="16" height="16" fill="none" stroke="#c70039" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
              </div>
              <div>
                <div class="font-medium text-gray-900 text-sm" data-i18n="contact.lbl.rne">RNE</div>
                <div class="text-gray-500 text-sm">1793146J</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-3 fade-in">
          <form id="contact-form" class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" data-i18n="form.name">Votre nom</label>
                <input name="contact-name" type="text" placeholder="Prénom Nom" data-i18n-placeholder="form.name.ph" required
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm text-gray-800 placeholder-gray-400 transition-colors" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5" data-i18n="form.email">Email</label>
                <input name="contact-email" type="email" placeholder="vous@exemple.com" data-i18n-placeholder="form.email.ph" required
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm text-gray-800 placeholder-gray-400 transition-colors" />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" data-i18n="form.phone">Téléphone</label>
              <div class="flex gap-2">
                <select id="phone-prefix"
                  class="border border-gray-200 rounded-lg px-3 py-3 text-sm text-gray-800 bg-white transition-colors flex-shrink-0 cursor-pointer"
                  style="min-width:100px">
                  <option value="+216">🇹🇳 +216</option>
                  <option value="+33">🇫🇷 +33</option>
                </select>
                <input id="phone-number" type="tel" placeholder="XX XXX XXX"
                  class="flex-1 border border-gray-200 rounded-lg px-4 py-3 text-sm text-gray-800 placeholder-gray-400 transition-colors" />
              </div>
              <p id="phone-error" class="hidden text-red-500 text-xs mt-1" data-i18n="form.phone.error">Numéro invalide — 8 chiffres pour +216, 9 à 10 chiffres pour +33.</p>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" data-i18n="form.subject">Sujet</label>
              <input name="contact-subject" type="text" placeholder="Votre sujet" data-i18n-placeholder="form.subject.ph" required
                class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm text-gray-800 placeholder-gray-400 transition-colors" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5" data-i18n="form.message">Message</label>
              <textarea name="contact-message" rows="4" placeholder="Décrivez votre projet ou votre demande..." data-i18n-placeholder="form.message.ph" required
                class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm text-gray-800 placeholder-gray-400 transition-colors resize-none"></textarea>
            </div>
            <button type="submit" class="btn-primary w-full text-center text-sm font-semibold py-3">
              <span data-i18n="form.submit">Envoyer le message</span>
            </button>
            <div id="form-success" class="hidden text-green-600 text-sm text-center font-medium py-2 bg-green-50 rounded-lg" data-i18n="form.success">✓ Votre message a bien été envoyé. Nous vous répondrons très prochainement.</div>
            <div id="form-error" class="hidden text-red-600 text-sm text-center font-medium py-2 bg-red-50 rounded-lg" data-i18n="form.error">✗ Une erreur est survenue. Veuillez vérifier votre connexion et réessayer.</div>
          </form>
        </div>
      </div>
    </div>
  </section>

<%- include('partials/footer') %>

<script>
  // Burger menu
  document.getElementById('burger').addEventListener('click', () =>
    document.getElementById('mobile-menu').classList.toggle('open'));

  // Lang switcher
  function toggleLangMenu() {
    document.getElementById('lang-dropdown').classList.toggle('open');
    document.getElementById('lang-chevron').classList.toggle('rotated');
  }
  document.addEventListener('click', e => {
    if (!document.getElementById('lang-switcher').contains(e.target)) {
      document.getElementById('lang-dropdown').classList.remove('open');
      document.getElementById('lang-chevron').classList.remove('rotated');
    }
  });

  let currentLang = localStorage.getItem('lang') || 'fr';
  const TRANSLATIONS = {};

  async function loadLang(lang) {
    if (!TRANSLATIONS[lang]) {
      try {
        const res = await fetch(`/assets/i18n/${lang}.json`);
        TRANSLATIONS[lang] = await res.json();
      } catch(e) { TRANSLATIONS[lang] = {}; }
    }
    currentLang = lang; localStorage.setItem('lang', lang);
    const dict = TRANSLATIONS[lang] || {};
    document.querySelectorAll('[data-i18n]').forEach(el => {
      if (dict[el.dataset.i18n] !== undefined) el.textContent = dict[el.dataset.i18n];
    });
    document.querySelectorAll('[data-i18n-html]').forEach(el => {
      if (dict[el.dataset.i18nHtml] !== undefined) el.innerHTML = dict[el.dataset.i18nHtml];
    });
    document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
      if (dict[el.dataset.i18nPlaceholder] !== undefined) el.placeholder = dict[el.dataset.i18nPlaceholder];
    });
    const isEN = lang === 'en';
    document.getElementById('lang-flag').textContent = isEN ? '🇬🇧' : '🇫🇷';
    document.getElementById('lang-label').textContent = isEN ? 'English' : 'Français';
    document.getElementById('opt-fr').classList.toggle('active', !isEN);
    document.getElementById('opt-en').classList.toggle('active', isEN);
    document.documentElement.lang = lang;
  }
  function setLang(lang) {
    loadLang(lang);
    document.getElementById('lang-dropdown').classList.remove('open');
    document.getElementById('lang-chevron').classList.remove('rotated');
  }
  loadLang(currentLang);

  // Scroll-based fade-in
  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) { entry.target.classList.add('visible'); observer.unobserve(entry.target); }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

  // Phone validation
  const phoneNumber = document.getElementById('phone-number');
  const phonePrefix = document.getElementById('phone-prefix');
  const phoneError  = document.getElementById('phone-error');

  function validatePhone() {
    const digits = phoneNumber.value.replace(/\s/g, '');
    const prefix = phonePrefix.value;
    let valid = true;
    if (digits.length > 0) {
      if (prefix === '+216') valid = /^\d{8}$/.test(digits);
      else if (prefix === '+33') valid = /^\d{9,10}$/.test(digits);
    }
    phoneError.classList.toggle('hidden', valid);
    phoneNumber.style.borderColor = (!valid && digits.length > 0) ? '#ef4444' : '';
    return valid || digits.length === 0;
  }

  const placeholders = { '+216': 'XX XXX XXX', '+33': 'XX XX XX XX XX' };

  phonePrefix.addEventListener('change', () => {
    phoneNumber.placeholder = placeholders[phonePrefix.value];
    phoneNumber.value = '';
    phoneError.classList.add('hidden');
    phoneNumber.style.borderColor = '';
  });

  phoneNumber.addEventListener('input', function() {
    const prefix = phonePrefix.value;
    const digits = this.value.replace(/\D/g, '');
    let formatted = '';
    if (prefix === '+33') {
      const d = digits.slice(0, 10);
      formatted = d.match(/.{1,2}/g)?.join(' ') ?? d;
    } else {
      const d = digits.slice(0, 8);
      if (d.length <= 2) formatted = d;
      else if (d.length <= 5) formatted = d.slice(0,2) + ' ' + d.slice(2);
      else formatted = d.slice(0,2) + ' ' + d.slice(2,5) + ' ' + d.slice(5);
    }
    this.value = formatted;
    validatePhone();
  });

  // EmailJS
  emailjs.init('vUJW1aDvhHR4GjOX8');

  const form = document.getElementById('contact-form');
  const submitBtn = form.querySelector('button[type="submit"]');
  const formSuccess = document.getElementById('form-success');
  const formError = document.getElementById('form-error');

  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    if (!validatePhone()) { phoneNumber.focus(); return; }

    const phone = phoneNumber.value.trim()
      ? phonePrefix.value + ' ' + phoneNumber.value.trim()
      : '';

    submitBtn.disabled = true;
    submitBtn.textContent = 'Envoi en cours…';
    formSuccess.classList.add('hidden');
    formError.classList.add('hidden');

    try {
      await emailjs.send('service_rqwhxgi', 'template_4926pxs', {
        name:    form.querySelector('[name="contact-name"]').value,
        email:   form.querySelector('[name="contact-email"]').value,
        phone:   phone,
        subject: form.querySelector('[name="contact-subject"]').value,
        message: form.querySelector('[name="contact-message"]').value,
      });
      formSuccess.classList.remove('hidden');
      form.reset();
      phoneError.classList.add('hidden');
      setTimeout(() => formSuccess.classList.add('hidden'), 6000);
    } catch (err) {
      console.error('EmailJS error:', err);
      formError.classList.remove('hidden');
      setTimeout(() => formError.classList.add('hidden'), 6000);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Envoyer le message';
    }
  });
</script>
</body>
</html>
